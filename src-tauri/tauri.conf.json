{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "cURL Runner",
  "version": "1.0.0",
  "identifier": "dev.curldisplay.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "cURL Runner",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Local curl runner with rich result visualization",
    "longDescription": "A desktop app that lets you paste, format and run curl commands locally — without browser CORS limitations.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
