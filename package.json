{
  "name": "curl-display",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n SERVER,WEB -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:web": "vite",
    "dev:server": "node server/index.js",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@tauri-apps/api": "^2.11.0",
    "cors": "^2.8.5",
    "element-plus": "^2.7.6",
    "express": "^4.19.2",
    "vue": "^3.4.31",
    "vue-i18n": "^11.4.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vue-tsc": "^2.0.22"
  }
}
